# IncidentIQ — PRODUCTION environment template.
# Copy to `.env` on your server and fill in real values. Treat this file as a
# secret. See docs/ONBOARDING.md for how to obtain each credential.

# ----------------------------------------------------------------------- App
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
# Restrict CORS to your real frontend origin (NOT *).
CORS_ORIGINS=https://incidentiq.yourcompany.com

# ------------------------------------------------------------------ Security
# REQUIRED: generate with `python -c "import secrets;print(secrets.token_urlsafe(48))"`
JWT_SECRET_KEY=__CHANGE_ME__
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# REQUIRED in production: disable demo users and create a real admin instead:
#   python scripts/create_admin.py --username you --role admin
SEED_DEMO_USERS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# ------------------------------------------------------------------ Database
# Managed PostgreSQL (pgvector image recommended). Run `alembic upgrade head` on deploy.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@db-host:5432/incidentiq
DATABASE_POOL_SIZE=20

# --------------------------------------------------------------------- Redis
REDIS_URL=redis://redis-host:6379/0

# ----------------------------------------------------------------------- LLM
# Set a key to enable real RCA; otherwise the deterministic engine is used.
LLM_PROVIDER=auto
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
RCA_AUTO_PROPOSE_THRESHOLD=0.6

# ----------------------------------------------- LIVE integrations (go real)
# Flip mock OFF, then configure each system you want connected.
INTEGRATIONS_MOCK_MODE=false

# Prometheus (metrics context)
PROMETHEUS_URL=http://prometheus.monitoring.svc:9090

# Kubernetes (self-healing actions: restart/scale/rollback)
KUBERNETES_ENABLED=true
KUBERNETES_NAMESPACE=production

# Slack (approval notifications) — bot token with chat:write, invited to the channel
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#sre

# PagerDuty (paging on critical) — Events API v2 routing/integration key
PAGERDUTY_ROUTING_KEY=

# GitHub (recent-deploy context) — fine-grained PAT, read-only on the repo
GITHUB_TOKEN=
GITHUB_REPO=your-org/your-service

# ------------------------------------------------------------- Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
