# IncidentIQ environment configuration.
# Copy to `.env` and adjust. EVERY value has a safe default — the app runs with
# an empty .env. Only the items marked (PROD) must be set for real deployments.

# ----------------------------------------------------------------------- App
ENVIRONMENT=local            # local | test | staging | production
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=true
CORS_ORIGINS=*               # comma-separated list of origins, or *

# ------------------------------------------------------------------ Database
# Local default is SQLite (no external service needed).
DATABASE_URL=sqlite+aiosqlite:///./incidentiq.db
# Production (Docker compose) uses PostgreSQL + pgvector:
# DATABASE_URL=postgresql+asyncpg://ai_sre_user:ai_sre_password@postgres:5432/ai_sre_db
DATABASE_ECHO=false

# --------------------------------------------------------------------- Redis
# Optional. Leave empty to use the in-process cache fallback.
REDIS_URL=
# REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------ Security
# (PROD) Generate a strong secret, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
JWT_SECRET_KEY=dev-insecure-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SEED_DEMO_USERS=true          # set false in production
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# ----------------------------------------------------------------------- LLM
# Multi-agent RCA. With no key, agents use the deterministic mock provider.
LLM_PROVIDER=auto             # auto | openai | mock
OPENAI_API_KEY=
# OPENAI_BASE_URL=            # optional (Azure OpenAI / proxy / local server)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800

# Embeddings: local deterministic hashing embedder by default (no network).
EMBEDDING_PROVIDER=local      # local | openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=256

# -------------------------------------------------------------------- Agents
RCA_AUTO_PROPOSE_THRESHOLD=0.6

# ------------------------------------------------- External integrations
# All integrations run in mock mode unless enabled + configured.
# To go live: set INTEGRATIONS_MOCK_MODE=false + the relevant creds, then run
# `python scripts/check_integrations.py`. See docs/ONBOARDING.md.
INTEGRATIONS_MOCK_MODE=true
PROMETHEUS_URL=http://localhost:9090
KUBERNETES_ENABLED=false
KUBERNETES_NAMESPACE=production
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#sre
PAGERDUTY_ROUTING_KEY=
GITHUB_TOKEN=
GITHUB_REPO=

# ------------------------------------------------------------- Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
